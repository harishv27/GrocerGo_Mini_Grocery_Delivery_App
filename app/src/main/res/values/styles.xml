<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="TextAppearance.GrocerGo.Title" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:fontFamily">@font/poppins_bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">22sp</item>
    </style>

    <style name="TextAppearance.GrocerGo.Subtitle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TextAppearance.GrocerGo.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:fontFamily">@font/poppins_regular</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TextAppearance.GrocerGo.Price" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:fontFamily">@font/poppins_bold</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="Card.GrocerGo" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/card_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="cardBackgroundColor">@color/card_bg</item>
        <item name="contentPadding">0dp</item>
    </style>

    <style name="SearchBar.GrocerGo" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">50dp</item>
        <item name="boxCornerRadiusTopEnd">50dp</item>
        <item name="boxCornerRadiusBottomStart">50dp</item>
        <item name="boxCornerRadiusBottomEnd">50dp</item>
        <item name="boxStrokeColor">@color/gray_200</item>
        <item name="boxBackgroundColor">@color/white</item>
        <item name="hintTextColor">@color/gray_400</item>
    </style>

    <style name="OTPInput.GrocerGo" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeWidth">2dp</item>
        <item name="boxStrokeColor">@color/primary</item>
    </style>

    <style name="BottomSheet.GrocerGo" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.GrocerGo.BottomSheet</item>
    </style>

    <style name="ShapeAppearance.GrocerGo.BottomSheet" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
    </style>
</resources>